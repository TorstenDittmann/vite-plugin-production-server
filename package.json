{
	"name": "vite-plugin-production-server",
	"version": "0.1.0",
	"description": "Vite plugin + production server for runtime-configurable environment variables",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.js"
		},
		"./env": {
			"types": "./env.d.ts"
		},
		"./virtual": {
			"types": "./virtual-modules.d.ts"
		}
	},
	"bin": {
		"vite-production-server": "./dist/bin.js",
		"vps": "./dist/bin.js"
	},
	"files": [
		"index.js",
		"bin",
		"src",
		"dist",
		"dist/**/*.d.ts",
		"env.d.ts",
		"virtual-modules.d.ts",
		"README.md"
	],
	"keywords": [
		"vite",
		"plugin",
		"environment",
		"runtime",
		"server",
		"production"
	],
	"author": "",
	"license": "MIT",
	"peerDependencies": {
		"vite": "^4.0.0 || ^5.0.0 || ^6.0.0"
	},
	"dependencies": {
		"citty": "^0.1.6",
		"sirv": "^2.0.4",
		"pathe": "^1.1.2",
		"defu": "^6.1.4",
		"consola": "^3.2.3"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/node": "^20.0.0",
		"typescript": "^5.0.0"
	},
	"scripts": {
		"dev": "tsc --watch",
		"build": "tsc",
		"prepublishOnly": "bun run build"
	}
}
